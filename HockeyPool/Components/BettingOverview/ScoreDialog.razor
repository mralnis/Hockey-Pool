@using static HockeyPool.Components.BettingOverview.BettingOverview

@attribute [Authorize]

@inject UnitOfWork unitOfWork;
@inject ISnackbar Snackbar

<MudDialog Style="background-color: rgba(55, 55, 64, 0.9);">
    <DialogContent>
        @if (_loading)
        {
            <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
        }
        else
        {
            <MudStack Spacing="4" AlignItems="AlignItems.Center">
                <!-- Country flags -->
                <MudStack Row="true" Justify="Justify.Center" AlignItems="AlignItems.Center" Spacing="6">
                    <span class="fi fi-@_homeCountryCode.ToLower()" style="width:50px;height:50px;"></span>
                    <MudText Typo="Typo.h6" Class="mx-4">VS</MudText>
                    <span class="fi fi-@_guestCountryCode.ToLower()" style="width:50px;height:50px;"></span>
                </MudStack>

                <!-- Score input form -->
                <MudForm @ref="_form" Style="width: 100%;">
                    <MudStack Row="true" Justify="Justify.Center" AlignItems="AlignItems.Start" Spacing="4">
                        <MudNumericField
                            @bind-Value="HomeScore"
                            Label="@_homeCountryName"
                            Variant="Variant.Outlined"
                            Required="true"
                            RequiredError="Nepieciešams rezultāts"
                            HelperText=" "
                            Min="0"
                            Max="20"
                            T="int?"
                            Style="max-width: 150px;" />

                        <MudText Typo="Typo.h6" Class="mt-4">:</MudText>

                        <MudNumericField
                            @bind-Value="GuestScore"
                            Label="@_guestCountryName"
                            Variant="Variant.Outlined"
                            Required="true"
                            RequiredError="Nepieciešams rezultāts"
                            HelperText=" "
                            Min="0"
                            Max="20"
                            T="int?"
                            Style="max-width: 150px;" />
                    </MudStack>

                    @if (!string.IsNullOrEmpty(_validationError))
                    {
                        <MudAlert Severity="Severity.Error" Class="mt-4">@_validationError</MudAlert>
                    }
                </MudForm>
            </MudStack>
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Atcelt</MudButton>
        <MudButton Color="Color.Primary" OnClick="Submit" Disabled="_loading">Saglabāt</MudButton>
    </DialogActions>
</MudDialog>

@code {
    private int? HomeScore { get; set; }
    private int? GuestScore { get; set; }
    private bool _loading = true;
    private string _homeCountryCode = "EU";
    private string _guestCountryCode = "EU";
    private string _homeCountryName = "";
    private string _guestCountryName = "";
    private string _validationError = "";
    private MudForm _form;

    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; }

    [Parameter]
    public Prediction Prediction { get; set; }

    [Parameter]
    public Matchup Matchup { get; set; }

    protected override async Task OnInitializedAsync()
    {
        await base.OnInitializedAsync();

        // Initialize score values from prediction
        HomeScore = Prediction.HomeTeamScore;
        GuestScore = Prediction.GuestTeamScore;

        // Load country data asynchronously
        await LoadCountryDataAsync();

        _loading = false;
    }

    private async Task LoadCountryDataAsync()
    {
        try
        {
            var homeCountry = await unitOfWork.CountryRepository.GetByIdAsync(Matchup.HomeTeamId);
            var guestCountry = await unitOfWork.CountryRepository.GetByIdAsync(Matchup.GuestTeamId);

            if (homeCountry != null)
            {
                _homeCountryCode = homeCountry.FlagCode;
                _homeCountryName = homeCountry.Name;
            }

            if (guestCountry != null)
            {
                _guestCountryCode = guestCountry.FlagCode;
                _guestCountryName = guestCountry.Name;
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Kļūda ielādējot valstu datus: {ex.Message}", Severity.Error);
        }
    }

    private async Task Submit()
    {
        _validationError = "";

        await _form.Validate();

        if (!_form.IsValid)
        {
            return;
        }

        // Validate that scores are not null (form validation should catch this, but double-check)
        if (!HomeScore.HasValue || !GuestScore.HasValue)
        {
            _validationError = "Lūdzu, ievadiet abus rezultātus";
            return;
        }

        // Validate that draws are not allowed
        if (HomeScore == GuestScore)
        {
            _validationError = "Neizšķirts nav atļauts! Lūdzu, iepazīstieties ar noteikumiem.";
            return;
        }

        // If scores haven't changed, just close the dialog
        if (Prediction.HomeTeamScore == HomeScore && Prediction.GuestTeamScore == GuestScore)
        {
            MudDialog.Cancel();
            return;
        }

        // Update prediction with new scores
        Prediction.HomeTeamScore = HomeScore;
        Prediction.GuestTeamScore = GuestScore;

        MudDialog.Close(DialogResult.Ok(true));
    }

    private void Cancel() => MudDialog.Cancel();
}
