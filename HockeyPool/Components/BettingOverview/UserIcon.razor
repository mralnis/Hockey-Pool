@foreach (var winner in Winners.Where(w => w.AspNetUserId == UserId))
{
    @if (winner.Place == 1)
    {
        <img src="./images/crown1.svg" width="16" height="16" style="margin-bottom:13px" title="Iepriekšējā gada uzvarētājs" alt="Iepriekšējā gada uzvarētājs" />
    }
    @if (winner.Place == 2)
    {
        <img src="./images/crown2.svg" width="16" height="16" style="margin-bottom:13px" title="Iepriekšējā gada 2. vieta" alt="Iepriekšējā gada 2. vieta" />
    }
    @if (winner.Place == 3)
    {
        <img src="./images/crown3.svg" width="16" height="16" style="margin-bottom:13px" title="Iepriekšējā gada 3. vieta" alt="Iepriekšējā gada 3. vieta" />
    }
}

@code {
    [Parameter]
    public string UserId { get; set; }

    [Parameter]
    public List<TournamentWinner> Winners { get; set; } = new();
}
